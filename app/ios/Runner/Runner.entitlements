<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Apple Push Notifications (FCM anti-theft wake-ups). Requires the Push
	     Notifications capability on the App ID + an APNs auth key uploaded to
	     Firebase (Apple Developer account). Until configured, iOS uses polling. -->
	<key>aps-environment</key>
	<string>development</string>

	<!-- App Groups - Required for sharing data with Network Extension -->
	<key>com.apple.security.application-groups</key>
	<array>
		<string>group.com.orb.guard.shared</string>
	</array>

	<!-- Network Extensions - Required for VPN and DNS filtering. The host app
	     also lists content-filter-provider because it hosts the OrbGuardFilter
	     NEFilterDataProvider content filter (managed via NEFilterManager on
	     MDM-supervised devices). -->
	<key>com.apple.developer.networking.networkextension</key>
	<array>
		<string>packet-tunnel-provider</string>
		<string>dns-proxy</string>
		<string>app-proxy-provider</string>
		<string>content-filter-provider</string>
	</array>

	<!-- Personal VPN - Required for VPN configuration -->
	<key>com.apple.developer.networking.vpn.api</key>
	<array>
		<string>allow-vpn</string>
	</array>

	<!-- Access WiFi Information - Required for NEHotspotNetwork.fetchCurrent
	     (current SSID/BSSID on the com.orb.guard/wifi channel) -->
	<key>com.apple.developer.networking.wifi-info</key>
	<true/>

	<!-- Keychain Sharing - For secure credential storage -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.orb.guard</string>
		<string>$(AppIdentifierPrefix)group.com.orb.guard.shared</string>
	</array>
</dict>
</plist>
