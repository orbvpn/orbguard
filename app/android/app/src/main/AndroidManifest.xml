<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ============================================ -->
    <!-- NETWORK PERMISSIONS (For threat intelligence) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- Android 13+ runtime notification permission (FCM push) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <!-- Required by WifiManager.startScan() for the com.orb.guard/wifi channel
         (network/rogue-AP scanning). Wi-Fi scan results additionally require
         ACCESS_FINE_LOCATION (declared below) and location services enabled;
         the channel returns PERMISSION_DENIED / LOCATION_DISABLED otherwise. -->
    <uses-permission android:name="android.permission.CHANGE_WIFI_STATE" />

    <!-- On-device firewall: a local VpnService that filters DNS. BIND_VPN_SERVICE
         is enforced on the service; the foreground-service perms keep the tunnel
         alive while active. RECEIVE_BOOT_COMPLETED lets BootReceiver restore the
         firewall after a reboot when the user left it enabled. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- ============================================ -->
    <!-- STORAGE PERMISSIONS (For file system scanning) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- ============================================ -->
    <!-- DEVICE INFO (For spyware detection) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />

    <!-- ============================================ -->
    <!-- SMS/CALL SCANNING (Pegasus exploits via SMS) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_CALL_LOG" />

    <!-- ============================================ -->
    <!-- PACKAGE USAGE (Monitor app behavior) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS"
        tools:ignore="ProtectedPermissions" />

    <!-- ============================================ -->
    <!-- ACCESSIBILITY (Detect malicious services) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE"
        tools:ignore="ProtectedPermissions" />

    <!-- ============================================ -->
    <!-- SYSTEM FEATURES (For deep scanning) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.GET_TASKS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="QueryAllPackagesPermission" />

    <!-- ============================================ -->
    <!-- LOCATION (Detect location stalkers) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- ============================================ -->
    <!-- DEVICE ADMIN (For threat removal) -->
    <!-- ============================================ -->
    <uses-permission android:name="android.permission.REQUEST_DELETE_PACKAGES" />

    <application
        android:label="OrbGuard"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:requestLegacyExternalStorage="true">

        <!-- Main Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Magic-link deep link: the OrbGuard-branded sign-in email links to
                 orbguard://login?code=... (backend chooses this scheme when the
                 request carries client=orbguard). Opens OrbGuard, not OrbVPN. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="orbguard" android:host="login" />
            </intent-filter>
        </activity>

        <!-- Flutter Embedding -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- Accessibility Service for detecting malicious services -->
        <service
            android:name=".AccessibilityMonitorService"
            android:exported="false"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- SMS Broadcast Receiver for real-time SMS protection -->
        <receiver
            android:name=".SMSReceiver"
            android:exported="true"
            android:permission="android.permission.BROADCAST_SMS">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Browser Accessibility Service for URL protection -->
        <service
            android:name=".BrowserAccessibilityService"
            android:exported="false"
            android:label="OrbGuard Web Protection"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/browser_accessibility_config" />
        </service>

        <!-- Messaging Accessibility Service for WhatsApp/Telegram protection -->
        <service
            android:name=".MessagingAccessibilityService"
            android:exported="false"
            android:label="OrbGuard Messaging Protection"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/messaging_accessibility_config" />
        </service>

        <!-- On-device network firewall (local DNS-filtering VpnService) -->
        <service
            android:name=".OrbFirewallVpnService"
            android:exported="false"
            android:permission="android.permission.BIND_VPN_SERVICE"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="On-device DNS firewall that blocks malicious domains" />
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <!-- Restores the firewall after a reboot or app update when the user
             left it enabled; posts an honest "tap to re-enable" notification
             instead when VPN consent must be granted again. exported=false is
             fine: both actions are protected system broadcasts, which the
             system delivers regardless (same pattern WorkManager uses). -->
        <receiver
            android:name=".BootReceiver"
            android:enabled="true"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED" />
            </intent-filter>
        </receiver>

        <!-- Device administrator for remote anti-theft LOCK / WIPE. Enabling it
             is an intrusive one-time user action (the ACTION_ADD_DEVICE_ADMIN
             system screen); until the user grants it DeviceAdminBridge
             .isAdminActive() is false and remote lock/wipe honestly fail.
             BIND_DEVICE_ADMIN is enforced by the OS so only the system can
             trigger the admin callbacks. Policies declared in
             res/xml/device_admin.xml (force-lock + wipe-data). -->
        <receiver
            android:name=".OrbDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>
    </application>

    <!-- Queries for Package Visibility (Android 11+) -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>

        <!-- Query all packages for scanning -->
        <intent>
            <action android:name="android.intent.action.MAIN" />
        </intent>

        <!-- Detect/launch the OrbVPN app for the VPN hand-off (orbvpn:// scheme). -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="orbvpn" />
        </intent>
    </queries>

</manifest>